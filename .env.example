# OpenAI API key (required for song generation)
OPENAI_API_KEY=sk-...

# Spotify API credentials (required for playlist creation)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# For production, set your Spotify app's redirect URI
# SPOTIFY_REDIRECT_URI=https://your-domain.com/api/spotify/callback

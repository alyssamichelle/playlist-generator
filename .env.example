# OpenAI API key (required for song generation)
OPENAI_API_KEY=sk-...

# Spotify API credentials (required for playlist creation)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# When API is on a different host, set frontend origin(s) for CORS (comma-separated)
# FRONTEND_URL=https://your-app.netlify.app

# Spotify redirect URI (must match Spotify Dashboard)
# Local: http://127.0.0.1:3001/api/spotify/callback
# Production: https://your-api.onrender.com/api/spotify/callback
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback

# Company Spotify account (optional) — lets users add playlists without connecting their own account
# Run OAuth once as the company account, then copy tokens from the callback URL
# SPOTIFY_COMPANY_ACCESS_TOKEN=BQC...
# SPOTIFY_COMPANY_REFRESH_TOKEN=AQC...
